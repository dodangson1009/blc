# Blockchain & Network Configuration (Sepolia Testnet Only)
# DO NOT commit this file. Copy to .env.local and fill in values.

# RPC URL (Sepolia)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Wallet Connect Project ID (optional, for WalletConnect)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Smart Contract Addresses (Sepolia)
NEXT_PUBLIC_DAI_ADDRESS=0x_YOUR_DAI_ADDRESS
NEXT_PUBLIC_DOGECOIN_ADDRESS=0x_YOUR_DOGECOIN_ADDRESS
NEXT_PUBLIC_LINK_ADDRESS=0x_YOUR_LINK_ADDRESS
NEXT_PUBLIC_USDC_ADDRESS=0x_YOUR_USDC_ADDRESS

# API Keys
NEXT_BACKEND_CMC_API_KEY=your_coinmarketcap_api_key
